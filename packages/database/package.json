{
  "name": "@medivisitas/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./enums": {
      "types": "./src/enums.ts",
      "default": "./src/enums.ts"
    }
  },
  "typesVersions": {
    "*": {
      "enums": [
        "./src/enums.ts"
      ]
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "dev": "prisma studio",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "push": "echo Use migrate:dev em vez de db push",
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
