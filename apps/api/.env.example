# ============================================
# MediVisitas API — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Clerk Auth
CLERK_SECRET_KEY="sk_test_..."
CLERK_JWT_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
CLERK_AUTHORIZED_PARTIES="http://localhost:5173,http://localhost:4321"
CLERK_WEBHOOK_SECRET="whsec_..."

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_BASICO="price_..."
STRIPE_PRICE_PROFISSIONAL="price_..."
STRIPE_PRICE_EQUIPE="price_..."
STRIPE_PRICE_IA_20="price_..."
STRIPE_PRICE_IA_50="price_..."
STRIPE_PRICE_IA_100="price_..."
STRIPE_PRICE_INDIVIDUAL="price_..." # Alias legado do Basico
STRIPE_PRICE_EMPRESA="price_..." # Alias legado do Equipe
STRIPE_PRICE_PACOTE_TRANSCRICOES="price_..." # Alias legado do IA +20

# Comercial
EMAIL_COMERCIAL="comercial@medivisitas.com"

# Gemini IA (Transcrição)
GEMINI_API_KEY=""

# URLs
FRONTEND_URL="http://localhost:5173"
LANDING_URL="http://localhost:4321"
APP_URL="http://localhost:5173"

# Servidor
PORT=3002
NODE_ENV="development"
