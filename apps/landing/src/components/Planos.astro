---
---

<section class="py-32 px-8 bg-surface-container-lowest">
  <div class="mx-auto w-full max-w-[1280px] flex flex-col items-center gap-16">
    <div class="text-center flex flex-col gap-4">
      <h2 class="text-[36px] font-semibold leading-[1.3] tracking-[-0.02em] text-on-surface">
        O valor da sua produtividade.
      </h2>
      <p class="text-lg leading-[1.6] text-on-surface-variant">
        Trial de 7 dias gratuito. Cancele quando quiser.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full max-w-4xl">
      <!-- Individual Plan -->
      <div class="bg-surface border border-outline-variant rounded-lg p-8 flex flex-col gap-8">
        <div>
          <h3 class="text-[24px] font-semibold leading-[1.4] tracking-[-0.01em] text-on-surface">Individual</h3>
          <p class="text-base leading-[1.6] text-on-surface-variant mt-2">Para propagandistas autônomos focados em performance.</p>
        </div>
        <div class="text-[36px] font-semibold leading-[1.3] tracking-[-0.02em] text-on-surface">
          R$ 79<span class="text-base leading-[1.6] text-on-surface-variant">/mês</span>
        </div>
        <ul class="flex flex-col gap-4 border-t border-outline-variant pt-8">
          <li class="flex items-center gap-3 text-base leading-[1.6] text-on-surface-variant">
            <span class="material-symbols-outlined text-primary text-[20px]">check</span>
            Cadastro ilimitado de profissionais
          </li>
          <li class="flex items-center gap-3 text-base leading-[1.6] text-on-surface-variant">
            <span class="material-symbols-outlined text-primary text-[20px]">check</span>
            Agenda inteligente com rotas
          </li>
          <li class="flex items-center gap-3 text-base leading-[1.6] text-on-surface-variant">
            <span class="material-symbols-outlined text-primary text-[20px]">check</span>
            Pipeline comercial completo
          </li>
          <li class="flex items-center gap-3 text-base leading-[1.6] text-on-surface-variant">
            <span class="material-symbols-outlined text-primary text-[20px]">check</span>
            Transcrição por IA (50/mês)
          </li>
        </ul>
        <a href="https://app.medivisitas.com/signup" class="mt-auto w-full py-4 border border-primary text-primary text-base font-semibold rounded text-center hover:bg-primary/5 transition-colors">
          Assinar Individual
        </a>
      </div>

      <!-- Empresa Plan -->
      <div class="bg-inverse-surface border border-inverse-surface rounded-lg p-8 flex flex-col gap-8 relative overflow-hidden">
        <div class="absolute top-0 right-0 bg-secondary text-on-secondary px-4 py-1 rounded-bl-lg text-[12px] font-bold uppercase tracking-[0.1em]">
          Recomendado
        </div>
        <div>
          <h3 class="text-[24px] font-semibold leading-[1.4] tracking-[-0.01em] text-inverse-on-surface">Empresa</h3>
          <p class="text-base leading-[1.6] text-outline-variant mt-2">Gestão centralizada para equipes de propagandistas.</p>
        </div>
        <div class="text-[36px] font-semibold leading-[1.3] tracking-[-0.02em] text-inverse-on-surface">
          R$ 49<span class="text-base leading-[1.6] text-outline-variant">/mês por usuário</span>
        </div>
        <ul class="flex flex-col gap-4 border-t border-outline/30 pt-8">
          <li class="flex items-center gap-3 text-base leading-[1.6] text-outline-variant">
            <span class="material-symbols-outlined text-secondary text-[20px]">check</span>
            Tudo do Individual
          </li>
          <li class="flex items-center gap-3 text-base leading-[1.6] text-outline-variant">
            <span class="material-symbols-outlined text-secondary text-[20px]">check</span>
            Múltiplos propagandistas
          </li>
          <li class="flex items-center gap-3 text-base leading-[1.6] text-outline-variant">
            <span class="material-symbols-outlined text-secondary text-[20px]">check</span>
            Dashboard do gestor
          </li>
          <li class="flex items-center gap-3 text-base leading-[1.6] text-outline-variant">
            <span class="material-symbols-outlined text-secondary text-[20px]">check</span>
            Transcrição por IA (ilimitada)
          </li>
        </ul>
        <a href="https://app.medivisitas.com/signup" class="mt-auto w-full py-4 bg-primary text-on-primary text-base font-semibold rounded text-center hover:bg-surface-tint transition-colors">
          Assinar Empresa
        </a>
      </div>
    </div>
  </div>
</section>
