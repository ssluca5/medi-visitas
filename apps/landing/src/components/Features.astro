---
const features = [
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>`, title: "Cadastro de Profissionais", desc: "CRM completo com pipeline de estágios. Acompanhe cada profissional desde a prospecção até a fidelização." },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`, title: "Agenda Inteligente", desc: "Calendário semanal com rotas otimizadas. Planeje suas visitas e nunca mais perca um compromisso." },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>`, title: "Pipeline Comercial", desc: "Funil visual: Prospectado → Visitado → Interessado → Prescritor → Fidelizado." },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>`, title: "Gravação com IA", desc: "Transcreva visitas automaticamente com inteligência artificial. Registre tudo sem digitar." },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>`, title: "Dashboard Analítico", desc: "KPIs, alertas e métricas em tempo real. Tome decisões baseadas em dados." },
  { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, title: "Multi-tenant", desc: "Gestão de equipes com isolamento de dados. Cada empresa com seu ambiente seguro." },
];
---

<section class="py-32 px-8 bg-surface">
  <div class="mx-auto max-w-[1280px]">
    <div class="text-center">
      <h2 class="features-h2 story-element" data-story-delay="1">Tudo que você precisa em um só lugar</h2>
      <p class="mt-4 text-xl leading-[1.6] text-ink-secondary story-element" data-story-delay="2">Funcionalidades pensadas para o dia a dia do propagandista farmacêutico</p>
    </div>
    <div class="mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f, i) => (
        <div class="rounded-xl border border-border bg-surface p-8 transition-shadow hover:shadow-sm story-element" data-story-delay="3" style={`animation-delay: ${0.2 + (i * 0.1)}s`}>
          <div class="w-9 h-9 rounded-lg flex items-center justify-center bg-blue-light text-blue-light-txt font-bold text-sm" set:html={f.icon}>
          </div>
          <h3 class="mt-4 text-[24px] font-semibold leading-[1.4] tracking-[-0.01em] text-ink">{f.title}</h3>
          <p class="mt-2 text-base leading-[1.6] text-ink-secondary">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* === Animações de Entrada === */
  @keyframes slideUpFade {
    0% {
      opacity: 0;
      transform: translateY(24px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes justFade {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }

  .story-element {
    opacity: 0; /* Inicia invisível */
    animation: slideUpFade 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  .story-element[data-story-delay="1"] { animation-delay: 0.1s; }
  .story-element[data-story-delay="2"] { animation-delay: 0.2s; }
  .story-element[data-story-delay="3"] { animation-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .story-element {
      animation-name: justFade;
      transform: none !important;
    }
  }

  .features-h2 {
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--color-ink);
    letter-spacing: -0.02em;
    line-height: 1.3;
  }
</style>
