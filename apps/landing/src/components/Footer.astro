---
const links = {
  produto: [
    { label: "Funcionalidades", href: "/funcionalidades" },
    { label: "Planos", href: "/planos" },
    { label: "Contato", href: "/contato" },
  ],
  empresa: [
    { label: "Termos de uso", href: "#" },
    { label: "Privacidade", href: "#" },
  ],
  conta: [
    { label: "Fazer login", href: "https://app.medivisitas.com/login" },
    { label: "Criar conta", href: "https://app.medivisitas.com/signup" },
  ],
};
---

<footer class="border-t border-outline-variant bg-surface-container-lowest">
  <div class="mx-auto max-w-[1280px] px-8 py-16">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href="/" class="text-lg font-bold text-on-surface">
          MediVisitas
        </a>
        <p class="mt-3 text-sm text-on-surface-variant">
          CRM para propagandistas farmacêuticos. Organize suas visitas e aumente suas prescrições.
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-on-surface">Produto</h3>
        <ul class="mt-3 space-y-2">
          {links.produto.map((link) => (
            <li><a href={link.href} class="text-sm text-on-surface-variant hover:text-on-surface">{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-on-surface">Empresa</h3>
        <ul class="mt-3 space-y-2">
          {links.empresa.map((link) => (
            <li><a href={link.href} class="text-sm text-on-surface-variant hover:text-on-surface">{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-on-surface">Conta</h3>
        <ul class="mt-3 space-y-2">
          {links.conta.map((link) => (
            <li><a href={link.href} class="text-sm text-on-surface-variant hover:text-on-surface">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-outline-variant pt-6 text-center text-sm text-on-surface-variant">
      &copy; 2026 MediVisitas. Todos os direitos reservados.
    </div>
  </div>
</footer>
