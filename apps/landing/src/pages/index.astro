---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Opening from "../components/Opening.astro";
import Pain from "../components/Pain.astro";
import Insight from "../components/Insight.astro";
import Solution from "../components/Solution.astro";
import Planos from "../components/Planos.astro";
import Proof from "../components/Proof.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

// Verificação server-side — sem loop, sem cookie frágil
const { userId } = Astro.locals.auth();
const appUrl = import.meta.env.PUBLIC_APP_URL || 'http://localhost:5173';

if (userId) {
  return Astro.redirect(`${appUrl}/dashboard`, 302);
}
---

<Base>
  <Header />
  <main id="main" role="main">
    <Opening />
    <Pain />
    <Insight />
    <Solution />
    <Planos />
    <Proof />
    <FAQ />
    <CTA />
  </main>
  <Footer />
</Base>