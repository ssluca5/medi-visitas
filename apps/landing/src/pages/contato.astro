---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Contato — MediVisitas" description="Entre em contato com o time MediVisitas. Estamos prontos para ajudar.">
  <Header />
  <main>
    <section class="pb-10 pt-24 text-center bg-surface">
      <h1 class="text-[48px] font-bold leading-[1.2] tracking-[-0.02em] text-on-surface">Contato</h1>
      <p class="mt-4 text-xl leading-[1.6] text-on-surface-variant">Estamos prontos para ajudar</p>
    </section>
    <section class="py-20 bg-surface-container-lowest">
      <div class="mx-auto max-w-2xl px-8">
        <div class="rounded-xl border border-outline-variant bg-surface p-8">
          <h2 class="text-xl font-bold text-on-surface">Fale conosco</h2>
          <div class="mt-6 space-y-4">
            <div>
              <h3 class="text-sm font-semibold text-on-surface">Email</h3>
              <a href="mailto:contato@medivisitas.com" class="text-sm text-primary hover:underline">contato@medivisitas.com</a>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-on-surface">WhatsApp</h3>
              <a href="https://wa.me/5500000000000" class="text-sm text-primary hover:underline">+55 (00) 00000-0000</a>
            </div>
          </div>
        </div>
        <div class="mt-10 rounded-xl border border-primary bg-primary/5 p-8 text-center">
          <h2 class="text-xl font-bold text-on-surface">Pronto para começar?</h2>
          <p class="mt-2 text-sm text-on-surface-variant">Crie sua conta e comece o trial gratuito de 7 dias.</p>
          <a href="https://app.medivisitas.com/signup" class="mt-6 inline-block rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-on-primary transition-opacity hover:opacity-90">
            Começar grátis
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
