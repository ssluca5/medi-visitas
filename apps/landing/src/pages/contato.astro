---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Contato — MediVisitas" description="Entre em contato com o time MediVisitas. Estamos prontos para ajudar.">
  <Header />
  <main>
    <section class="contact-hero" aria-labelledby="contact-h1">
      <div class="contact-hero-inner">
        <h1 class="contact-h1 story-element" id="contact-h1" data-story-delay="0">Estamos prontos<br />para ajudar.</h1>
        <p class="contact-sub story-element" data-story-delay="2">Fale com nosso time comercial ou envie uma mensagem.</p>
      </div>
    </section>

    <section class="contact-body">
      <div class="contact-grid">
        <article class="contact-card story-element" data-story-delay="0">
          <div class="contact-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h2 class="contact-card-title">Email</h2>
          <p class="contact-card-desc">Envie sua dúvida ou solicite uma demonstração.</p>
          <a href="mailto:contato@medivisitas.com" class="contact-card-link">contato@medivisitas.com</a>
        </article>

        <article class="contact-card story-element" data-story-delay="1">
          <div class="contact-card-icon whatsapp">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h2 class="contact-card-title">WhatsApp</h2>
          <p class="contact-card-desc">Atendimento rápido para dúvidas comerciais.</p>
          <a href="https://wa.me/5500000000000" class="contact-card-link">+55 (00) 00000-0000</a>
        </article>

        <article class="contact-card story-element" data-story-delay="2">
          <div class="contact-card-icon schedule">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h2 class="contact-card-title">Agendar demonstração</h2>
          <p class="contact-card-desc">Veja o MediVisitas funcionando ao vivo, com um especialista.</p>
          <a href="mailto:contato@medivisitas.com?subject=Demonstração MediVisitas" class="contact-card-link">Solicitar demonstração →</a>
        </article>
      </div>

      <!-- CTA Banner — abre a modal -->
      <div class="contact-cta story-element" data-story-delay="3">
        <div class="contact-cta-content">
          <h2 class="contact-cta-title">Prefere enviar uma mensagem?</h2>
          <p class="contact-cta-desc">Preencha nosso formulário de contato e entraremos em contato com você.</p>
        </div>
        <button type="button" id="open-contact-modal" class="btn btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Enviar mensagem
        </button>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<!-- Modal de Contato -->
<div id="contact-modal" class="modal-overlay" aria-hidden="true">
  <div class="modal-backdrop" id="modal-backdrop"></div>
  <div class="modal-container" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal-panel">
      <!-- Header -->
      <div class="modal-header">
        <div class="modal-header-left">
          <div class="modal-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </div>
          <div>
            <h2 id="modal-title" class="modal-title">Envie sua mensagem</h2>
            <p class="modal-subtitle">Preencha os campos abaixo para entrar em contato.</p>
          </div>
        </div>
        <button type="button" id="close-contact-modal" class="modal-close" aria-label="Fechar">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <!-- Form -->
      <form id="contact-form" class="modal-form">
        <div class="modal-form-row">
          <div class="modal-form-group">
            <label for="contact-name" class="modal-label">Nome completo <span style="color: #dc2626;">*</span></label>
            <input
              type="text"
              id="contact-name"
              name="name"
              placeholder="Seu nome"
              required
              style="width: 100%; height: 44px; padding: 0 14px; font-size: 15px; font-family: inherit; color: #111827; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 10px; outline: none;"
            />
          </div>
          <div class="modal-form-group">
            <label for="contact-email" class="modal-label">E-mail <span style="color: #dc2626;">*</span></label>
            <input
              type="email"
              id="contact-email"
              name="email"
              placeholder="seu@email.com"
              required
              style="width: 100%; height: 44px; padding: 0 14px; font-size: 15px; font-family: inherit; color: #111827; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 10px; outline: none;"
            />
          </div>
        </div>

        <div class="modal-form-group">
          <label for="contact-subject" class="modal-label">Assunto</label>
          <select
            id="contact-subject"
            name="subject"
            style="width: 100%; height: 44px; padding: 0 14px; font-size: 15px; font-family: inherit; color: #111827; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 10px; outline: none; cursor: pointer; padding-right: 36px;"
          >
            <option value="">Selecione um assunto...</option>
            <option value="demonstracao">Solicitar demonstração</option>
            <option value="duvidas">Dúvidas sobre o produto</option>
            <option value="planos">Informações sobre planos</option>
            <option value="suporte">Suporte técnico</option>
            <option value="parceria">Proposta de parceria</option>
            <option value="outro">Outro</option>
          </select>
        </div>

        <div class="modal-form-group">
          <label for="contact-message" class="modal-label">Mensagem <span style="color: #dc2626;">*</span></label>
          <textarea
            id="contact-message"
            name="message"
            placeholder="Conte como podemos ajudar..."
            rows="5"
            required
            style="width: 100%; padding: 12px 14px; font-size: 15px; font-family: inherit; color: #111827; background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 10px; outline: none; min-height: 120px; resize: vertical; line-height: 1.6;"
          ></textarea>
        </div>

        <!-- Footer -->
        <div class="modal-footer">
          <button type="button" id="cancel-contact-modal" class="btn btn-secondary modal-cancel-btn">Cancelar</button>
          <button type="submit" class="btn btn-primary modal-submit-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Enviar mensagem
          </button>
        </div>
      </form>

      <!-- Success state -->
      <div id="contact-success" class="modal-success" style="display: none;">
        <div class="success-icon-wrap">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="success-title">Mensagem enviada!</h3>
        <p class="success-desc">Obrigado pelo contato. Nossa equipe responderá o mais breve possível.</p>
        <button type="button" id="success-close" class="btn btn-primary" style="margin-top: 8px;">Fechar</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const openBtn = document.getElementById('open-contact-modal');
    const closeBtn = document.getElementById('close-contact-modal');
    const cancelBtn = document.getElementById('cancel-contact-modal');
    const backdrop = document.getElementById('modal-backdrop');
    const modal = document.getElementById('contact-modal');
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const success = document.getElementById('contact-success');
    const successClose = document.getElementById('success-close');

    if (!openBtn || !closeBtn || !cancelBtn || !backdrop || !modal || !form || !success || !successClose) return;

    function openModal() {
      modal!.classList.add('is-open');
      modal!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Focus first input after animation
      setTimeout(() => {
        const firstInput = form!.querySelector('input') as HTMLInputElement | null;
        firstInput?.focus();
      }, 200);
    }

    function closeModal() {
      modal!.classList.remove('is-open');
      modal!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Reset to form view
      form!.style.display = '';
      success!.style.display = 'none';
      form!.reset();
    }

    openBtn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    successClose.addEventListener('click', closeModal);

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal!.classList.contains('is-open')) {
        closeModal();
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const name = formData.get('name') as string;
      const email = formData.get('email') as string;
      const subject = formData.get('subject') as string;
      const message = formData.get('message') as string;

      const subjectLine = subject
        ? `[MediVisitas] ${subject} — ${name}`
        : `[MediVisitas] Contato — ${name}`;
      const body = `Nome: ${name}\nE-mail: ${email}\n\n${message}`;
      const mailtoUrl = `mailto:contato@medivisitas.com?subject=${encodeURIComponent(subjectLine)}&body=${encodeURIComponent(body)}`;

      window.location.href = mailtoUrl;

      // Show success
      form.style.display = 'none';
      success.style.display = 'flex';
    });
  });
</script>

<style>
  /* === Hero === */
  .contact-hero {
    background: var(--color-off-white);
    padding: 140px clamp(24px, 5vw, 80px) 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .contact-hero::before {
    content: "";
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 100%;
    background: radial-gradient(ellipse at center, rgba(37, 99, 235, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact-hero-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }

  .contact-h1 {
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 800;
    font-family: var(--font-display);
    color: var(--color-ink);
    letter-spacing: -0.025em;
    line-height: 1.0;
    margin-top: 16px;
  }

  .contact-sub {
    font-size: 20px;
    color: var(--color-ink-secondary);
    margin-top: 20px;
    line-height: 1.6;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  /* === Body === */
  .contact-body {
    background: var(--color-surface);
    padding: 80px clamp(24px, 5vw, 80px) 120px;
  }

  .contact-grid {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* === Cards === */
  .contact-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 36px;
    transition: transform 250ms, box-shadow 250ms, border-color 250ms;
  }

  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -15px rgba(37, 99, 235, 0.15);
    border-color: var(--color-blue);
  }

  .contact-card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-blue-light);
    color: var(--color-blue);
  }

  .contact-card-icon.whatsapp {
    background: var(--color-green-light);
    color: var(--color-green);
  }

  .contact-card-icon.schedule {
    background: color-mix(in srgb, var(--color-purple) 10%, transparent);
    color: var(--color-purple);
  }

  .contact-card-title {
    font-size: 20px;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--color-ink);
    margin-top: 20px;
    letter-spacing: -0.01em;
  }

  .contact-card-desc {
    font-size: 15px;
    color: var(--color-ink-secondary);
    margin-top: 8px;
    line-height: 1.6;
  }

  .contact-card-link {
    display: inline-block;
    margin-top: 16px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-blue);
    text-decoration: none;
    transition: color 200ms;
  }

  .contact-card-link:hover {
    color: var(--color-blue-hover);
    text-decoration: underline;
  }

  /* === CTA Banner === */
  .contact-cta {
    max-width: 1120px;
    margin: 48px auto 0;
    background: var(--color-blue-light);
    border: 1px solid color-mix(in srgb, var(--color-blue) 20%, transparent);
    border-radius: 20px;
    padding: 40px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .contact-cta-title {
    font-size: 24px;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--color-ink);
    letter-spacing: -0.01em;
  }

  .contact-cta-desc {
    font-size: 15px;
    color: var(--color-ink-secondary);
    margin-top: 6px;
    line-height: 1.5;
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
    }

    .contact-cta {
      flex-direction: column;
      align-items: flex-start;
      text-align: left;
    }
  }

  /* === Animações de Entrada === */
  @keyframes slideUpFade {
    0% {
      opacity: 0;
      transform: translateY(24px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .story-element {
    opacity: 0;
    animation: slideUpFade 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  .story-element[data-story-delay="0"] { animation-delay: 0s; }
  .story-element[data-story-delay="1"] { animation-delay: 0.1s; }
  .story-element[data-story-delay="2"] { animation-delay: 0.2s; }
  .story-element[data-story-delay="3"] { animation-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .story-element {
      animation-name: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<!-- Modal styles — is:global because the modal is outside the Astro component scope -->
<style is:global>
  /* === Modal Overlay === */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 250ms ease;
  }

  .modal-overlay.is-open {
    pointer-events: auto;
    opacity: 1;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .modal-container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 560px;
    max-height: 90vh;
    margin: 0 20px;
    transform: translateY(20px) scale(0.97);
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .modal-overlay.is-open .modal-container {
    transform: translateY(0) scale(1);
  }

  .modal-panel {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 25px 60px -12px rgba(0, 0, 0, 0.25);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 90vh;
  }

  /* === Modal Header === */
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 28px 20px;
    border-bottom: 1px solid #e5e7eb;
  }

  .modal-header-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .modal-icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #eff6ff;
    color: #2563eb;
  }

  .modal-title {
    font-size: 18px;
    font-weight: 700;
    font-family: var(--font-display, 'Sora', system-ui, sans-serif);
    color: #111827;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .modal-subtitle {
    font-size: 14px;
    color: #6b7280;
    margin-top: 2px;
    line-height: 1.4;
  }

  .modal-close {
    width: 36px;
    height: 36px;
    min-width: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    border: none;
    background: transparent;
    color: #9ca3af;
    cursor: pointer;
    transition: background 150ms, color 150ms;
  }

  .modal-close:hover {
    background: #f3f4f6;
    color: #374151;
  }

  /* === Modal Form === */
  .modal-form {
    padding: 24px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    overflow-y: auto;
  }

  .modal-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .modal-form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .modal-label {
    font-size: 14px;
    font-weight: 600;
    color: #111827;
  }

  /* Focus styles for modal inputs */
  .modal-form input:focus,
  .modal-form select:focus,
  .modal-form textarea:focus {
    border-color: #2563eb !important;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .modal-form input::placeholder,
  .modal-form textarea::placeholder {
    color: #9ca3af;
  }

  /* === Modal Footer === */
  .modal-footer {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    padding-top: 8px;
    border-top: 1px solid #f3f4f6;
    margin-top: 4px;
    padding-top: 20px;
  }

  .modal-cancel-btn {
    height: 44px !important;
    padding: 0 20px !important;
    font-size: 15px !important;
  }

  .modal-submit-btn {
    height: 44px !important;
    padding: 0 24px !important;
    font-size: 15px !important;
  }

  /* === Modal Success === */
  .modal-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 48px 28px;
    gap: 12px;
    animation: modalFadeIn 0.3s ease forwards;
  }

  .success-icon-wrap {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #d1fae5;
    color: #059669;
    margin-bottom: 4px;
  }

  .success-title {
    font-size: 22px;
    font-weight: 700;
    font-family: var(--font-display, 'Sora', system-ui, sans-serif);
    color: #111827;
  }

  .success-desc {
    font-size: 15px;
    color: #6b7280;
    max-width: 360px;
    line-height: 1.6;
  }

  @keyframes modalFadeIn {
    0% { opacity: 0; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* === Modal Responsive === */
  @media (max-width: 600px) {
    .modal-form-row {
      grid-template-columns: 1fr;
    }

    .modal-container {
      margin: 0 12px;
    }

    .modal-header {
      padding: 20px 20px 16px;
    }

    .modal-form {
      padding: 20px;
    }

    .modal-footer {
      flex-direction: column-reverse;
    }

    .modal-cancel-btn,
    .modal-submit-btn {
      width: 100% !important;
    }
  }
</style>
