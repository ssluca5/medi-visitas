---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Planos from "../components/Planos.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Planos — MediVisitas" description="Escolha o plano ideal para você ou sua equipe. Trial de 7 dias gratuito.">
  <Header />
  <main>
    <section class="pb-10 pt-24 text-center bg-off-white">
      <h1 class="text-[48px] font-bold leading-[1.2] tracking-[-0.02em] text-ink">Planos</h1>
      <p class="mt-4 text-xl leading-[1.6] text-ink-secondary">Escolha o plano ideal para o seu momento</p>
    </section>
    <Planos />
    <CTA />
  </main>
  <Footer />
</Base>
