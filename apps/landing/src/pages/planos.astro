---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Planos from "../components/Planos.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";

const faq = [
  { q: "Posso mudar de plano depois?", a: "Sim! Você pode fazer upgrade a qualquer momento. Os dados são preservados." },
  { q: "Preciso de cartão de crédito para o trial?", a: "Não. O trial de 7 dias é 100% gratuito, sem cartão de crédito." },
  { q: "O que é multi-tenant?", a: "Cada empresa tem seu ambiente isolado com dados e usuários separados." },
  { q: "Como funciona a transcrição por IA?", a: "Você grava a visita pelo app e a IA transcreve automaticamente o conteúdo." },
];
---

<Base title="Planos — MediVisitas" description="Escolha o plano ideal para você ou sua equipe. Trial de 7 dias gratuito.">
  <Header />
  <main>
    <section class="pb-10 pt-24 text-center bg-surface">
      <h1 class="text-[48px] font-bold leading-[1.2] tracking-[-0.02em] text-on-surface">Planos</h1>
      <p class="mt-4 text-xl leading-[1.6] text-on-surface-variant">Escolha o plano ideal para o seu momento</p>
    </section>
    <Planos />
    <section class="py-20 bg-surface-container-lowest">
      <div class="mx-auto max-w-3xl px-8">
        <h2 class="text-center text-[36px] font-semibold leading-[1.3] tracking-[-0.02em] text-on-surface">Perguntas frequentes</h2>
        <div class="mt-10 space-y-6">
          {faq.map((item) => (
            <div class="border-b border-outline-variant pb-6">
              <h3 class="font-semibold text-on-surface">{item.q}</h3>
              <p class="mt-2 text-sm text-on-surface-variant">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    <CTA />
  </main>
  <Footer />
</Base>
